<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_centerInParent="true"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/img_accueil"
        android:layout_width="260dp"
        android:layout_height="260dp"
        android:src="@drawable/e_wallet_animate"
        android:scaleType="centerInside"
        android:layout_marginBottom="40dp"
        android:elevation="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Prêt Bancaire App"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:textAlignment="center"
        android:layout_marginBottom="12dp"
        android:letterSpacing="-0.02"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gérez vos simulations, vos clients et vos analyses financières en toute simplicité."
        android:textSize="16sp"
        android:textColor="#5C6BC0"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="50dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_entrer"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="COMMENCER"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3F51B5"
        app:cornerRadius="20dp"
        app:elevation="4dp"
        android:letterSpacing="0.1" />

</LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="20dp"
        android:text="Version 1.0 - 2026"
        android:textColor="#BDBDBD"
        android:textSize="12sp" />

</RelativeLayout>